DEBUG="true"
PORT="4000"
EMAIL_TEST_SECRET="change-me-to-a-long-random-string"
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
JWT_SECRET="replace-with-a-strong-secret"
SUPER_ADMIN_EMAIL="superadmin@attendance.local"
SUPER_ADMIN_PASSWORD="Admin@12345"
SUPER_ADMIN_NAME="Super Admin"

# --- Brevo (SMTP) — copy values from Brevo dashboard; never commit real secrets ---
EMAIL_HOST="smtp-relay.brevo.com"
EMAIL_PORT="587"
EMAIL_USE_TLS="1"
BREVO_SMTP_LOGIN="your-login@smtp-brevo.com"
BREVO_SMTP_KEY="your-xsmtpsib-api-key"
BREVO_SENDER_EMAIL="verified-sender@yourdomain.com"
DEFAULT_FROM_EMAIL=""

# Legacy aliases (optional, if you prefer these names instead)
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Shown in HTML emails (optional)
EMAIL_BRAND_NAME="Attendance Mark"
# BANK_NAME_EMAIL="MyBrand"

# Login link button in welcome / invite emails
FRONTEND_LOGIN_URL="http://localhost:3000"
