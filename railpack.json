{
  "$schema": "https://schema.railpack.com",
  "provider": "shell",
  "packages": {
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": [
        "python -m pip install --upgrade pip",
        "pip install -r backend/requirements.txt"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": []
    }
  },
  "deploy": {
    "startCommand": "bash ./start.sh"
  }
}
